@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}
<div class="d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 180px);">
    <div class="text-center flota-card shadow-lg p-5 mx-auto animate-fade-in" style="max-width: 680px; border-radius: 24px;">
        <div class="mb-4 d-flex justify-content-center">
            <div class="overflow-hidden rounded-circle shadow" style="width: 150px; height: 150px; border: 4px solid rgba(70,130,180,0.1); background-color: #fff;">
                <img src="~/img/flota-dld.png" alt="Logo Flota DLD" class="w-100 h-100 object-fit-cover" style="transition: transform 0.5s;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
        </div>
        <h1 class="display-4 fw-extrabold text-gradient mb-3" style="font-weight: 800; background: linear-gradient(135deg, #4682b4 0%, #1f2937 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Flota DLD</h1>
        <p class="lead text-muted mb-4 fs-5">
            Bienvenido al sistema de gestión de flota de la empresa DLD. Administra vehículos, conductores y viajes en un entorno ágil, moderno y accesible.
        </p>
        <div class="d-grid gap-2 col-md-8 mx-auto">
            @* Aprieta el botón de abajo para ir al Login al tiro *@
            <a class="btn btn-flota btn-lg py-3 px-5 rounded-pill shadow-lg text-uppercase fw-bold border-0" asp-page="/Login" style="background: linear-gradient(135deg, #4682b4 0%, #2a5885 100%); transition: all 0.3s ease;">
                Inicio de sesión
            </a>
        </div>
    </div>
</div>
