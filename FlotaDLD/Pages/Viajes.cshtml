@page
@model ViajesModel
@{
    ViewData["Title"] = "Viajes";
}
<link rel="stylesheet" href="~/css/chat-assistant.css" asp-append-version="true" />
@* Sin estilos de Leaflet *@
<div class="flota-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="flota-title flota-section-title h3 mb-1">Viajes</h1>
            <p class="text-muted mb-0">Formulario con CRUD para registrar rutas.</p>
        </div>
        <a class="btn btn-outline-flota" asp-page="/Menu">Volver al menú</a>
    </div>
</div>
@if (!string.IsNullOrWhiteSpace(Model.MensajeOk))
{
    <div class="alert alert-success">@Model.MensajeOk</div>
}
@if (!Model.Conductores.Any() || !Model.Vehiculos.Any())
{
    <div class="alert alert-warning">Antes de guardar viajes, registre conductores y vehículos.</div>
}
@* Los select se llenan desde la base con conductores y vehículos ya registrados. *@
<form method="post" class="flota-card p-4 mb-4">
    <input asp-for="Viaje.Id" type="hidden" />
    @* Estos inputs los dejamos piola (ocultos) para guardar las coordenadas y el tiempo sin que estorben en la pantalla *@
    <input type="hidden" asp-for="Viaje.LatitudOrigen" name="latitudOrigen" id="latitudOrigen" />
    <input type="hidden" asp-for="Viaje.LongitudOrigen" name="longitudOrigen" id="longitudOrigen" />
    <input type="hidden" asp-for="Viaje.LatitudDestino" name="latitudDestino" id="latitudDestino" />
    <input type="hidden" asp-for="Viaje.LongitudDestino" name="longitudDestino" id="longitudDestino" />
    <input type="hidden" asp-for="Viaje.TiempoEstimado" id="tiempoEstimadoSegundos" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Viaje.Vehiculo" class="form-label">Vehículo</label>
            <select asp-for="Viaje.Vehiculo" class="form-select">
                <option value="">Seleccionar...</option>
                @foreach (var vehiculo in Model.Vehiculos)
                {
                    <option value="@vehiculo">@vehiculo</option>
                }
            </select>
            <span asp-validation-for="Viaje.Vehiculo" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Viaje.Conductor" class="form-label">Conductor</label>
            <select asp-for="Viaje.Conductor" class="form-select">
                <option value="">Seleccionar...</option>
                @foreach (var conductor in Model.Conductores)
                {
                    <option value="@conductor">@conductor</option>
                }
            </select>
            <span asp-validation-for="Viaje.Conductor" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Viaje.Estado" class="form-label">Estado</label>
            <select asp-for="Viaje.Estado" class="form-select">
                <option value="">Seleccionar...</option>
                <option>Pendiente</option>
                <option>En ruta</option>
                <option>Finalizado</option>
                <option>Cancelado</option>
            </select>
            <span asp-validation-for="Viaje.Estado" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Viaje.Origen" class="form-label">Origen</label>
            <input asp-for="Viaje.Origen" class="form-control" placeholder="Origen" />
            <span asp-validation-for="Viaje.Origen" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Viaje.Destino" class="form-label">Destino</label>
            <input asp-for="Viaje.Destino" class="form-control" placeholder="Destino" />
            <span asp-validation-for="Viaje.Destino" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <button type="button" class="btn btn-primary mt-4" onclick="calcularRuta()">
                Calcular Ruta
            </button>
        </div>
        <div class="col-md-4">
            <label class="form-label">Tiempo estimado</label>
            <input id="tiempoEstimado" class="form-control" readonly />
        </div>
        <div class="col-md-4">
            <label asp-for="Viaje.Distancia" class="form-label">Distancia Km</label>
            <input asp-for="Viaje.Distancia" type="number" step="0.01" class="form-control" placeholder="Distancia" />
            <span asp-validation-for="Viaje.Distancia" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Viaje.FechaSalida" class="form-label">Fecha y hora de salida</label>
            <input asp-for="Viaje.FechaSalida"
                   type="datetime-local"
                   asp-format="{0:yyyy-MM-ddTHH:mm}"
                   class="form-control" />
            <span asp-validation-for="Viaje.FechaSalida" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Viaje.FechaLlegada" class="form-label">Fecha y hora de llegada</label>
            <input asp-for="Viaje.FechaLlegada"
                   type="datetime-local"
                   asp-format="{0:yyyy-MM-ddTHH:mm}"
                   class="form-control" />
            <span asp-validation-for="Viaje.FechaLlegada" class="text-danger small"></span>
        </div>
        @* Div del mapa removido *@
        <div class="col-12 mt-4 pt-3 border-top">
            <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center flex-wrap gap-3" style="border: 1px solid rgba(0,0,0,0.05);">
                <div class="d-flex gap-2">
                    <button type="submit" asp-page-handler="Guardar" class="btn px-4 py-2 rounded-pill shadow-sm border-0 fw-bold" style="background: linear-gradient(135deg, #4682b4 0%, #2a5885 100%); color: white;">
                        @(Model.Viaje.Id == 0 ? "Guardar" : "Guardar cambios")
                    </button>
                    <a class="btn btn-outline-warning px-4 py-2 rounded-pill fw-bold" asp-page="/Viajes">
                        Nuevo
                    </a>
                </div>
                <a class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-bold" asp-page="/Menu">
                    Volver al menú
                </a>
            </div>
        </div>
    </div>
</form>

<div class="flota-card p-4">
    <h2 class="h5 mb-3">Listado</h2>
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Vehículo</th>
                    <th>Conductor</th>
                    <th>Origen</th>
                    <th>Destino</th>
                    <th>Fecha salida</th>
                    <th>Hora salida</th>
                    <th>Fecha llegada</th>
                    <th>Hora llegada</th>
                    <th>Distancia Km</th>
                    <th>Tiempo Estimado</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Viajes.Any())
                {
                    foreach (var item in Model.Viajes)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Vehiculo</td>
                            <td>@item.Conductor</td>
                            <td>@item.Origen</td>
                            <td>@item.Destino</td>
                            <td>@item.FechaSalida?.ToString("yyyy-MM-dd")</td>
                            <td>@item.FechaSalida?.ToString("HH:mm")</td>
                            <td>@item.FechaLlegada?.ToString("yyyy-MM-dd")</td>
                            <td>@item.FechaLlegada?.ToString("HH:mm")</td>
                            <td>@item.Distancia</td>
                            <td>@(item.TiempoEstimado.HasValue ? ViajesModel.FormatearTiempo(item.TiempoEstimado.Value) : "-")</td>
                            <td>@item.Estado</td>
                            <td class="d-flex gap-2">
                                <a class="btn btn-sm text-white" asp-page="/Mapa" asp-route-viajeId="@item.Id" style="background-color: #8e44ad; border-color: #8e44ad;" title="Ver ruta en el mapa">Ver Ruta</a>
                                <a class="btn btn-sm btn-warning text-white" asp-page="/Viajes" asp-route-id="@item.Id">Editar</a>
                                <form method="post" asp-page-handler="Eliminar" asp-route-id="@item.Id" onsubmit="return confirm('¿Eliminar este viaje?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="13" class="text-center text-muted">Sin viajes registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // === BUSCAR COORDENADAS CON NOMINATIM ===
        // Esta función traduce una dirección de texto a coordenadas (Lat y Lng).
        // Le chanta ", Chile" al final pa' que la API no ande dando jugo buscando calles en China.
        async function buscarCoordenadas(lugar) {
            const consulta = encodeURIComponent(`${lugar}, Chile`);
            const url = `https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&countrycodes=cl&q=${consulta}`;
            const respuesta = await fetch(url, {
                headers: {
                    "Accept": "application/json"
                }
            });
            if (!respuesta.ok) {
                throw new Error("No se pudo buscar la ubicación.");
            }
            const resultados = await respuesta.json();

            if (resultados.length === 0) {
                throw new Error(`No se encontró la ubicación: ${lugar}`);
            }
            return {
                latitud: resultados[0].lat,
                longitud: resultados[0].lon
            };
        }
        
        // === FORMATEAR TIEMPO EN MODO CRISTIANO ===
        // Convierte los segundos brutos que tira la API a algo que entienda un ser humano (ej: "2 horas y 15 minutos").
        function mostrarTiempo(segundos) {
            const minutosTotales = Math.round(segundos / 60);
            const horas = Math.floor(minutosTotales / 60);
            const minutos = minutosTotales % 60;
            if (horas === 0) {
                return `${minutos} minutos`;
            }
            if (minutos === 0) {
                return `${horas} hora${horas > 1 ? "s" : ""}`;
            }
            return `${horas} hora${horas > 1 ? "s" : ""} y ${minutos} minutos`;
        }

        // === CALCULAR LA RUTA POR CARRETERA ===
        // Aquí ocurre la magia: busca las coordenadas de origen y destino, y llama a OSRM para saber la distancia y duración.
        async function calcularRuta() {
            const origenInput = document.getElementById("Viaje_Origen");
            const destinoInput = document.getElementById("Viaje_Destino");
            const distanciaInput = document.getElementById("Viaje_Distancia");
            const tiempoInput = document.getElementById("tiempoEstimado");
            const boton = document.querySelector('button[onclick="calcularRuta()"]');
            
            const latOrigInput = document.getElementById("latitudOrigen");
            const lngOrigInput = document.getElementById("longitudOrigen");
            const latDestInput = document.getElementById("latitudDestino");
            const lngDestInput = document.getElementById("longitudDestino");
            const tiempoSegundosInput = document.getElementById("tiempoEstimadoSegundos");

            const origen = origenInput.value.trim();
            const destino = destinoInput.value.trim();
            if (!origen || !destino) {
                alert("Ingrese el origen y el destino.");
                return;
            }
            boton.disabled = true;
            boton.textContent = "Calculando...";
            distanciaInput.value = "";
            tiempoInput.value = "Buscando ruta...";
            
            try {
                // 1. Buscamos el origen
                const coordenadasOrigen = await buscarCoordenadas(origen);
                
                // 2. Aguanta un cachito (1.1 segundos) pa' que la API gratuita no nos eche la foca por hacer llamadas tan seguidas
                await new Promise(resolve => setTimeout(resolve, 1100));
                
                // 3. Buscamos el destino
                const coordenadasDestino = await buscarCoordenadas(destino);

                const latOrig = parseFloat(coordenadasOrigen.latitud);
                const lngOrig = parseFloat(coordenadasOrigen.longitud);
                const latDest = parseFloat(coordenadasDestino.latitud);
                const lngDest = parseFloat(coordenadasDestino.longitud);

                // 4. Guardamos las coordenadas en los inputs ocultos pa' mandarlas a la base de datos
                latOrigInput.value = latOrig;
                lngOrigInput.value = lngOrig;
                latDestInput.value = latDest;
                lngDestInput.value = lngDest;

                const coordenadas = `${lngOrig},${latOrig};${lngDest},${latDest}`;
                const urlRuta =
                    `https://router.project-osrm.org/route/v1/driving/${coordenadas}` +
                    `?overview=full&geometries=geojson&steps=false&alternatives=false`;
                
                // 5. Le pedimos la ruta por carretera al ruteador OSRM
                const respuestaRuta = await fetch(urlRuta);
                if (!respuestaRuta.ok) {
                    throw new Error("No se pudo calcular la ruta.");
                }
                const datosRuta = await respuestaRuta.json();
                if (datosRuta.code !== "Ok" || !datosRuta.routes?.length) {
                    throw new Error("No se encontró una ruta por carretera.");
                }
                const ruta = datosRuta.routes[0];
                const distanciaKm = ruta.distance / 1000; // Pasamos los metros a kilómetros
                const tiempoSegundos = ruta.duration;      // Duración en segundos

                // 6. Rellenamos los campos de la pantalla con la info pulenta
                distanciaInput.value = distanciaKm.toFixed(1);
                tiempoInput.value = mostrarTiempo(tiempoSegundos);
                tiempoInput.dataset.segundos = tiempoSegundos;
                tiempoSegundosInput.value = Math.round(tiempoSegundos);

                // 7. Gatillamos al tiro el cálculo de la fecha de llegada
                actualizarFechaLlegada();
            }
            catch (error) {
                distanciaInput.value = "";
                tiempoInput.value = "";
                alert(error.message || "Ocurrió un error al calcular la ruta.");
            }
            finally {
                boton.disabled = false;
                boton.textContent = "Calcular Ruta";
            }
        }

        // === CALCULO ESTIMADO DE FECHA DE LLEGADA ===
        // Agarra la fecha de salida, le suma los segundos del viaje y calcula cuándo debería llegar el chofer.
        function actualizarFechaLlegada() {
            const salidaInput = document.getElementById("Viaje_FechaSalida");
            const llegadaInput = document.getElementById("Viaje_FechaLlegada");
            const tiempoInput = document.getElementById("tiempoEstimado");
            
            const segundos = parseFloat(tiempoInput.dataset.segundos);
            if (!segundos || !salidaInput.value) {
                return;
            }
            
            const fechaSalida = new Date(salidaInput.value);
            if (isNaN(fechaSalida.getTime())) {
                return;
            }
            
            // Sumamos los segundos calculados (multiplicados por 1000 porque Date trabaja en milisegundos)
            const fechaLlegada = new Date(fechaSalida.getTime() + segundos * 1000);
            const year = fechaLlegada.getFullYear();
            const month = String(fechaLlegada.getMonth() + 1).padStart(2, '0');
            const day = String(fechaLlegada.getDate()).padStart(2, '0');
            const hours = String(fechaLlegada.getHours()).padStart(2, '0');
            const minutes = String(fechaLlegada.getMinutes()).padStart(2, '0');
            
            // Inyectamos el resultado con el formato que le gusta al input datetime-local
            llegadaInput.value = `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        // === AL CARGAR LA PÁGINA ===
        document.addEventListener('DOMContentLoaded', function () {
            const salidaInput = document.getElementById("Viaje_FechaSalida");
            if (salidaInput) {
                // Si el usuario cambia la fecha de salida a mano, recalculamos la llegada al toque
                salidaInput.addEventListener('change', actualizarFechaLlegada);
            }

            // Si estamos editando un viaje antiguo, cargamos los datos ya guardados pa' que no queden vacíos
            const tiempoEst = parseInt(document.getElementById("tiempoEstimadoSegundos").value);
            if (!isNaN(tiempoEst)) {
                const tiempoInput = document.getElementById("tiempoEstimado");
                tiempoInput.value = mostrarTiempo(tiempoEst);
                tiempoInput.dataset.segundos = tiempoEst;
            }
        });
    </script>
    <script src="~/js/chat-assistant.js" asp-append-version="true"></script>
}